      {
        "name": "recency_bias",
        "behavior": "recency_bias",
        "cases": [
          {
            "case_id": "recency_001",
            "prompt": "The trophy would not fit in the suitcase because the suitcase was too small. The word 'small' refers to the",
            "choices": {
              "A": " suitcase",
              "B": " trophy"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "recency_bias"
            }
          },
          {
            "case_id": "recency_002",
            "prompt": "The ball would not fit in the bag because the bag was too narrow. The word 'narrow' refers to the",
            "choices": {
              "A": " bag",
              "B": " ball"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "recency_bias"
            }
          },
          {
            "case_id": "recency_003",
            "prompt": "The cat could not catch the mouse because the mouse was too fast. The word 'fast' refers to the",
            "choices": {
              "A": " mouse",
              "B": " cat"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "recency_bias"
            }
          },
          {
            "case_id": "recency_004",
            "prompt": "The painting would not fit on the wall because the wall was too narrow. The word 'narrow' refers to the",
            "choices": {
              "A": " wall",
              "B": " painting"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "recency_bias"
            }
          }
        ],
        "description": "Recency-sensitive resolution of attributive adjectives."
      },
