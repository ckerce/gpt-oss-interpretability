      {
        "name": "coreference",
        "behavior": "coreference",
        "cases": [
          {
            "case_id": "coref_002",
            "prompt": "The teacher praised the student because the student got every answer right. Later, the teacher said he would recommend the student for the award. The word 'he' refers to the",
            "choices": {
              "A": " teacher",
              "B": " student"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "coreference"
            }
          },
          {
            "case_id": "coref_003",
            "prompt": "John called Mary and told her about the meeting. The word 'her' refers to",
            "choices": {
              "A": " Mary",
              "B": " John"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "coreference"
            }
          },
          {
            "case_id": "coref_004",
            "prompt": "The mother picked up the child because she was strong enough to carry him. The word 'she' refers to the",
            "choices": {
              "A": " mother",
              "B": " child"
            },
            "expected_label": "A",
            "metadata": {
              "phenomenon": "coreference"
            }
          }
        ],
        "description": "Simple pronoun coreference resolution."
      }
